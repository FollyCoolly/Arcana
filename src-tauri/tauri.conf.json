{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "arcana",
  "version": "0.1.0",
  "identifier": "com.zhsu.arcana",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Arcana",
        "width": 1200,
        "height": 800,
        "resizable": false,
        "maximizable": false,
        "alwaysOnTop": false,
        "decorations": false,
        "shadow": false,
        "transparent": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
